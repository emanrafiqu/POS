# ---- Veloura POS Server ----
PORT=5000

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# Path to the Firebase service account JSON (download from
# Firebase Console > Project Settings > Service Accounts > Generate new private key)
# Used for LOCAL DEVELOPMENT only.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# For serverless hosting (e.g. Vercel), paste the full service account JSON here
# (or its base64 encoding) instead of using GOOGLE_APPLICATION_CREDENTIALS,
# since serverless platforms have no persistent filesystem for secret files.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Firebase Storage bucket (e.g. your-project-id.appspot.com)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
