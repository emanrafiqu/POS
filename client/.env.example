# ---- Firebase Web App configuration ----
# Firebase Console > Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# ---- Express API base URL ----
# Local dev: leave as /api (the Vite dev server proxies it to localhost:5000).
# Vercel/production: set to the full URL of the deployed server project's API,
# e.g. https://veloura-api.vercel.app/api
VITE_API_BASE_URL=/api
